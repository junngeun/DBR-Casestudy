# backend 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고, 빈 값은 팀장에게 받아서 채우세요.
#   Windows: copy .env.example .env
#   Mac    : cp .env.example .env

PORT=3000

# DB 접속 정보 (팀장에게 받으세요)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# 프론트엔드 주소 (로컬 개발은 아래 값 그대로)
FRONTEND_URL=http://localhost:5173

# JWT (아무 문자열이나 가능하지만, 팀원끼리 같은 값을 써야 토큰이 호환됩니다)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 구글 OAuth (팀장에게 받으세요)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 로컬 개발은 아래 값 그대로. 이 주소가 구글 콘솔의 '승인된 리디렉션 URI'에 등록돼 있어야 합니다.
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
