# ai-server 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고, 값은 팀장에게 받아서 채우세요.
#   Windows: copy .env.example .env
#   Mac    : cp .env.example .env
#
# 주의: 이 파일의 위치는 ai-server/app/.env 입니다 (ai-server/.env 아님)

# OpenAI API 키 (팀장에게 받으세요)
OPENAI_API_KEY=

# DB 접속 정보 (backend/.env 와 같은 값)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
